│   ├── config
│   └── utils
│
├── frontend
│   ├── pages
│   ├── components
│   ├── services
│   ├── hooks
│   └── context
│
└── docs

## Installation

### Clone Repository

git clone <repo-url>

### Backend Setup

cd backend  
npm install  
npm run dev

### Frontend Setup

cd frontend  
npm install  
npm run dev